# === 数据库 ===
DATABASE_URL=postgresql+asyncpg://kbuser:kbpass@localhost:5432/knowledge_base

# === 向量数据库 ===
QDRANT_URL=http://localhost:6333

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === MinIO 对象存储 ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=knowledge-base

# === Ollama 本地模型 ===
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=bge-m3
LLM_MODEL=qwen2.5:7b

# === OpenAI (可选，替代本地模型) ===
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_LLM_MODEL=gpt-4o-mini

# === 应用配置 ===
SECRET_KEY=your-secret-key-change-this
APP_NAME=Enterprise Knowledge Base
DEBUG=true
LOG_LEVEL=DEBUG

# === 分块策略 ===
CHUNK_SIZE=512
CHUNK_OVERLAP=128

# === 检索参数 ===
TOP_K_VECTOR=30
TOP_K_BM25=20
RERANK_TOP_K=5

# === SMTP 邮件配置（用于密码重置）===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=CogniBase <noreply@example.com>
SMTP_TLS=true

# === 前端地址 ===
FRONTEND_URL=http://localhost:3000

# === OAuth 第三方登录 ===
# 后端回调的前缀。生产环境设置为对外可访问的后端域名。
OAUTH_BACKEND_BASE_URL=http://localhost:8000
# 登录成功后跳转的前端地址
OAUTH_FRONTEND_CALLBACK=http://localhost:3000/oauth-callback

# Microsoft (Azure AD App Registration)
# 在 https://portal.azure.com -> 应用注册 创建"Web"平台应用，
# 重定向 URI 填写：${OAUTH_BACKEND_BASE_URL}${OAUTH_MICROSOFT_CALLBACK_PATH}
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# tenant: common=多租户（个人+企业账号），organizations=仅企业，consumers=仅个人
MICROSOFT_TENANT=common

# GitHub (Settings -> Developer settings -> OAuth Apps -> New OAuth App)
# Authorization callback URL 填写：${OAUTH_BACKEND_BASE_URL}${OAUTH_GITHUB_CALLBACK_PATH}
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
